        "context_required": ["pending_cancel"]
      }
    ],
    "complexity": "low"
  },
  
  "shipping_address_change": {
    "description": "배송지 변경 전체 흐름",
    "turns": [
      {
        "user": "{order_id} 배송지 바꾸고 싶어",
        "intent": "change_shipping_address",
        "expected_tool": "get_order_detail"
      },
      {
        "user": "등록된 주소 보여줘",
        "intent": "view_addresses",
        "expected_tool": "get_address_list"
      },
      {
        "user": "두 번째 주소로 변경해줘",
        "intent": "confirm_address_change",
        "expected_tool": "update_shipping_address",
        "context_required": ["order_id", "address_list"]
      }
    ],
    "complexity": "high"
  },
  
  "return_exchange_clarification": {
    "description": "반품/교환 구분 확인",
    "turns": [
      {
        "user": "사이즈가 안맞아",
        "intent": "complaint",
        "expected_response": "clarification_question"
      },
      {
        "user": "교환하고 싶어",
        "intent": "exchange_request",
        "expected_tool": "process_exchange",
        "context_required": ["previous_complaint"]
      },
      {
        "user": "L 사이즈로 바꿔줘",
        "intent": "specify_exchange_option",
        "expected_action": "update_exchange_details",
        "context_required": ["pending_exchange"]
      }
    ],
    "complexity": "high"
  },
  
  "point_inquiry_then_use": {
    "description": "포인트 확인 후 사용",
