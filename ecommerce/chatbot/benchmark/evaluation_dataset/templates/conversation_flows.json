  "ambiguous_request_clarification": {
    "description": "모호한 요청 명확화",
    "turns": [
      {
        "user": "배송이 왜 안와?",
        "intent": "complaint",
        "expected_response": "request_order_info"
      },
      {
        "user": "어제 주문했어",
        "intent": "provide_time_info",
        "expected_tool": "get_order_list",
        "filters": ["recent_orders"]
      },
      {
