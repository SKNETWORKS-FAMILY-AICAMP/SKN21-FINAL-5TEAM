      {
        "user": "최근 주문 알려줘",
        "intent": "order_lookup",
        "expected_tool": "get_order_list"
      },
      {
        "user": "두 번째꺼 자세히 보여줘",
        "intent": "order_detail",
        "expected_tool": "get_order_detail",
        "context_required": ["order_list"]
      }
    ],
    "complexity": "medium"
  },
  
  "knowledge_search_then_action": {
    "description": "정책 확인 후 행동",
