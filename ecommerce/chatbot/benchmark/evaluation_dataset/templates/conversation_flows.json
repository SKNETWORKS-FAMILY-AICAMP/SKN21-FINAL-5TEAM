{
  "order_lookup_then_cancel": {
    "description": "주문 조회 후 취소",
    "turns": [
      {
        "user": "내 주문 내역 보여줘",
        "intent": "order_lookup",
        "expected_tool": "get_order_list",
        "expected_ui_action": "show_order_list"
      },
      {
        "user": "첫 번째 주문 취소할래",
        "intent": "cancel_order",
        "expected_tool": "cancel_order",
        "context_required": ["order_list"]
      }
    ],
    "complexity": "medium"
  },
  
  "order_lookup_then_detail": {
    "description": "주문 조회 후 상세 확인",
