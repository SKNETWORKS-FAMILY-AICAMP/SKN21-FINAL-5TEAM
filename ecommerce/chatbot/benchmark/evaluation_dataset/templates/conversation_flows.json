  "complex_order_issue": {
    "description": "복잡한 주문 문제 해결",
    "turns": [
      {
        "user": "주문번호 {order_id} 조회해줘",
        "intent": "order_lookup",
        "expected_tool": "get_order_detail"
      },
      {
        "user": "이거 언제 도착해?",
        "intent": "shipping_inquiry",
        "expected_response": "shipping_info_from_context",
        "context_required": ["order_detail"]
      },
      {
        "user": "너무 늦는데 배송지 바꿀 수 있어?",
        "intent": "change_shipping_address",
        "expected_tool": "update_shipping_address",
        "validation_required": true
      },
      {
        "user": "안되면 취소할래",
        "intent": "cancel_order",
        "expected_tool": "cancel_order",
        "context_required": ["order_id", "previous_failure"]
      }
    ],
    "complexity": "very_high"
  },
  
