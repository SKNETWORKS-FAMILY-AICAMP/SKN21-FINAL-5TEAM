        "intent": "provide_product_info",
        "expected_action": "filter_orders_by_product",
        "context_required": ["order_list"]
      },
      {
        "user": "그거 조회해줘",
        "intent": "confirm_selection",
        "expected_tool": "get_order_detail",
        "context_required": ["filtered_order"]
      }
    ],
    "complexity": "very_high"
  },
  
  "multi_action_request": {
    "description": "여러 작업 동시 요청",
    "turns": [
      {
        "user": "주문번호 {order_id_1}은 취소하고 {order_id_2}는 배송지 바꿔줘",
