{
  "description": "Supervisor 라우팅 평가 데이터셋. 사용자 발화가 4개 subagent 중 올바른 곳으로 라우팅되는지 평가.",
  "routing_targets": {
    "order_intent_router": {
      "description": "주문 관련 CS (취소/반품/교환/배송조회/주문목록)",
      "templates": [
        "주문 취소해주세요",
        "방금 결제한 거 취소하고 싶어요",
        "잘못 주문했는데 취소 가능해요?",
        "환불 받고 싶어요",
        "반품 신청할게요",
        "물건이 불량이라 돈 돌려받고 싶어요",
        "사이즈 교환하고 싶어요",
        "다른 색상으로 바꿀 수 있을까요?",
        "옵션 변경하고 싶은데 교환 돼요?",
        "배송 어디까지 왔어요?",
        "택배 언제 도착하나요?",
        "송장번호 알려주세요",
        "내 주문 내역 보여줘",
        "최근 주문 목록 조회해줘",
        "그동안 뭐 샀는지 주문 내역 확인하고 싶어요"
      ]
    },
    "discovery_subagent": {
      "description": "상품 탐색/추천 (텍스트 또는 이미지 기반)",
      "sub_routes": {
        "text_search": {
          "description": "텍스트 기반 상품 검색/추천",
          "templates": [
            "봄에 입기 좋은 옷 추천해줘",
            "데이트할 때 입을 만한 코디 찾아줘",
            "출근복으로 괜찮은 정장 보여줘",
            "운동할 때 편한 바지 추천 좀",
            "캐주얼한 느낌 아우터 있어?"
          ]
        },
        "image_search": {
          "description": "이미지 URL 포함 상품 검색",
          "templates": [
            "이 사진이랑 비슷한 옷 찾아줘 {image_url}",
            "이것과 비슷한 스타일 보여줘 {image_url}",
            "{image_url} 이거랑 같은 종류 있어?",
            "SNS에서 본 건데 비슷한 거 있나요 {image_url}"
          ]
        }
      }
    },
    "policy_rag_subagent": {
      "description": "배송/환불/교환 정책 및 약관 질의",
      "templates": [
        "환불 정책 알려줘",
        "배송 규정이 어떻게 되나요?",
        "교환 기한이 얼마예요?",
        "반품 택배비 누가 부담해요?",
        "개봉한 것도 돌려보낼 수 있어요?",
        "제주도도 배송비 같은가요?"
      ]
    },
    "form_action_subagent": {
      "description": "폼 기반 액션 (중고등록, 리뷰작성, 상품권등록)",
      "sub_routes": {
        "register_used_item": {
          "description": "중고상품 등록/판매",
          "templates": [
            "중고 등록하고 싶어요",
            "안 입는 옷 팔고 싶어요",
            "사이즈 안 맞는 옷 중고로 내놓을래요",
            "새 거나 다름없는 신발 올리고 싶어",
            "옷장 정리하는데 안 입는 거 처분하고 싶어"
          ]
        },
        "write_review": {
          "description": "리뷰/후기 작성",
          "templates": [
            "리뷰 쓰고 싶어요",
            "후기 남기고 싶어요",
            "별점 주고 싶은데 어디서 해요?",
            "착용 사진이랑 후기를 올리고 싶어요",
            "구매평 작성하는 곳이 어디예요?"
          ]
        },
        "register_gift_card": {
          "description": "상품권/쿠폰 등록",
          "templates": [
            "상품권 등록해주세요",
            "기프트카드 번호 입력하고 싶어요",
            "이벤트 당첨 코드 어디에 넣어요?",
            "모바일 상품권은 어떻게 적용해요?",
            "회사에서 받은 포인트 코드 등록해주세요"
          ]
        }
      }
    }
  },
  "generation_config": {
    "variations_per_template": 3,
    "llm_model": "gpt-4o-mini",
    "temperature": 0.7
  }
}
