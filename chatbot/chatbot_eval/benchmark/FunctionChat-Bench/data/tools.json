                    "search_mode": {
                        "type": "string",
                        "description": "검색 모드 (similar, opposite 등)",
                        "default": "similar"
                    }
                },
                "required": [
                    "query"
                ]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "search_by_image",
            "description": "CLIP/Qdrant를 활용해 업로드된 이미지와 유사한 상품을 추천합니다.",
