    {
        "type": "function",
        "function": {
            "name": "recommend_clothes",
            "description": "사용자의 요청(카테고리, 색상, 용도 등)에 맞는 옷을 추천합니다. 챗봇이 의류나 패션 아이템을 추천할 때 사용합니다.",
            "parameters": {
                "type": "object",
                "properties": {
                    "category": {
                        "type": "string",
                        "description": "의류 종류 (필수, 예: \"Topwear\", \"Bottomwear\", \"Dress\", \"Skirt\", \"Innerwear\" 등. 사용자의 발화를 기반으로 영어 분류명으로 추론하세요)"
                    },
                    "color": {
                        "type": "string",
                        "description": "색상 (선택사항, 예: \"Black\", \"Red\", \"Blue\" 등 영어 색상명)",
                        "default": null
                    },
                    "usage": {
                        "type": "string",
                        "description": "용도 (선택사항, 예: \"Casual\", \"Formal\", \"Sports\", \"Party\" 등 영어 용도명)",
                        "default": null
                    },
                    "season": {
                        "type": "string",
                        "description": "계절 (선택사항, 예: \"Summer\", \"Winter\", \"Fall\", \"Spring\")",
                        "default": null
                    },
                    "limit": {
                        "type": "integer",
                        "description": "추천할 상품 최대 개수 (기본값 3)",
                        "default": 3
                    },
                    "user_id": {
                        "type": "integer",
                        "description": "사용자 ID (기본값 1, DB에서 성별 조회용)",
                        "default": 1
                    }
                },
                "required": [
                    "category"
                ]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "search_by_text_clip",
            "description": "CLIP 텍스트 임베딩 기반으로 상품 이미지를 검색합니다. 추천/무드/스타일 검색에 사용합니다.",
