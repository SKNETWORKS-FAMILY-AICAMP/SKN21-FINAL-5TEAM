[
    {
        "type": "function",
        "function": {
            "name": "shipping",
            "description": "주문의 배송 현황과 택배사 정보를 통합 조회합니다. 배송 상태, 현재 위치, 예상 도착일, 택배사 정보(이름/전화번호) 등을 반환합니다.",
            "parameters": {
                "type": "object",
                "properties": {
                    "order_id": {
                        "type": "string",
                        "description": "주문번호"
                    },
                    "user_id": {
                        "type": "integer",
                        "description": "요청자 사용자 ID",
                        "default": 1
                    },
                    "access_token": {
                        "type": "string",
                        "description": "인증 토큰",
                        "default": null
                    }
                },
                "required": []
            }
        }
    },
    {
